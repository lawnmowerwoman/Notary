            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "DisableRemoteManagement": {
          "type": "string",
          "default": "check",
          "title": "2.4.9 Apple Remote Management deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "DisableContentCaching": {
          "type": "string",
          "default": "check",
          "title": "2.4.10 Content Caching deaktivieren",
