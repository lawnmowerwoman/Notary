{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "de.twocent.notary",
  "title": "Twocent Labs Notary – Apfelwerk Konfiguration 1.3",
  "description": "CIS/BSI-nahe Härtungs- und Reporting-Optionen für den Runner.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "Org": {
      "type": "object",
      "title": "Organisation",
      "propertyOrder": 10,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "OrgName": { "type": "string", "title": "Organisationsname (Login-Meldung)" },
        "OrgContact": { "type": "string", "title": "Kontakt (Mail/Telefon)" }
      }
    },

    "CoreSecurity": {
      "type": "object",
      "title": "Core Security",
      "propertyOrder": 20,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "required": ["UpdateXProtect"],
      "properties": {
        "UpdateXProtect": {
          "type": "string",
          "default": "check",
          "title": "XProtect automatisches Update",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "CheckFileVaultStatus": {
          "type": "string",
          "default": "check",
          "title": "2.5.1.1 FileVault aktiv",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"]
          }
        },
        "CheckGateKeeperStatus": {
          "type": "string",
          "default": "check",
          "title": "2.5.2.1 Gatekeeper aktiv ('Anywhere' versteckt)",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"]
          }
        },
        "CheckSIPStatus": {
          "type": "string",
          "default": "check",
          "title": "5.18 SIP aktiv",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"]
          }
        },
        "CheckARStatus": {
          "type": "string",
          "default": "check",
          "title": "5.19 SSV/Authenticated Root aktiv",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"]
          }
        }
      }
    },

    "Firewall": {
      "type": "object",
      "title": "Firewall",
      "propertyOrder": 30,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "EnableFirewall": {
          "type": "string",
          "default": "check",
          "title": "2.5.2.1 macOS Firewall aktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "EnableFirewallStealthMode": {
          "type": "string",
          "default": "check",
          "title": "2.5.2.3 Stealth Mode aktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "EnableFirewallBlockAllIncoming": {
          "type": "string",
          "default": "check",
          "title": "Alle eingehenden Verbindungen blockieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "EnableFirewallAllowSigned": {
          "type": "string",
          "default": "check",
          "title": "Signierte Verbindungen erlauben",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        }
      }
    },

    "DiagnosticsAudit": {
      "type": "object",
      "title": "Diagnose & Auditing",
      "propertyOrder": 40,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "DisableDiagnosticData": {
          "type": "string",
          "default": "check",
          "title": "2.5.5 Diagnose-/Nutzungsdaten an Apple deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "EnableSecurityAuditing": {
          "type": "string",
          "default": "check",
          "title": "3.1 Security Auditing aktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "EnableAuditFailureHalt": {
          "type": "string",
          "default": "check",
          "title": "Audit Failure-Halt (ahlt) aktivieren",
          "description": "Prüft oder erzwingt, dass macOS bei einem Audit-Fehler in den Halt-Modus wechselt (`ahlt`). Das ist vor allem für strengere NIST- und CIS-Profile relevant, damit fehlgeschlagene Audit-Schreibvorgänge nicht unbemerkt bleiben.",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "ConfigureAuditFlagsCore": {
          "type": "string",
          "default": "check",
          "title": "Audit Kern-Flags konfigurieren",
          "description": "Prüft oder setzt den empfohlenen Kernsatz an Audit-Flags in `/etc/security/audit_control`. Damit werden sicherheitsrelevante Ereignisse wie Admin-Aktionen, Login-/Logout-Aktivitäten und Dateisystem-Fehler konsistent protokolliert.",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "RetainInstallLog": {
          "type": "string",
          "default": "check",
          "title": "3.3 Retain install.log for 365 days",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "LimitAuditRecordsAccess": {
          "type": "string",
          "default": "check",
          "title": "3.5 Zugriff auf Audit-Records (nur root)",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        }
      }
    },

    "Location": {
      "type": "object",
      "title": "Ortungsdienste",
      "propertyOrder": 50,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "EnableLocationServices": {
          "type": "string",
          "default": "check",
          "title": "2.5.3 Location Services aktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        }
      }
    },

    "ScreenSaver": {
      "type": "object",
      "title": "Bildschirmschoner",
      "propertyOrder": 60,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "SetScreenSaverDelay": {
          "type": "string",
          "default": "check",
          "title": "2.3.1 Inaktivitäts-Timeout erzwingen",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "ScreenSaverDelay": {
          "type": "integer",
          "default": 1200,
          "title": "Inaktivitäts-Timeout",
          "enum": [180, 300, 600, 1200],
          "options": {
            "enum_titles": ["3 Minuten", "5 Minuten", "10 Minuten", "20 Minuten"],
            "hidden": false,
            "show_if": { "SetScreenSaverDelay": "check" }
          },
          "watch": { "SetScreenSaverDelay": "root.ScreenSaver.SetScreenSaverDelay" }
        },
        "RequirePasswordOnWake": {
          "type": "string",
          "default": "off",
          "title": "5.9 Passwort nach Sleep/Bildschirmschoner verlangen",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"],
            "hidden": false,
            "show_if": { "SetScreenSaverDelay": "check" }
          }
        },
        "ScreenSaverPasswordDelay": {
          "type": "integer",
          "default": 5,
          "title": "5.9.1 Passwort nach Bildschirmschoner oder Display Deaktivierung erforderlich",
          "enum": [0, 5, 60, 300],
          "options": {
            "enum_titles": ["Sofort", "≤ 5 Sekunden", "≤ 1 Minute", "≤ 5 Minuten"],
            "hidden": false,
            "show_if": { "SetScreenSaverDelay": "check" }
          },
          "watch": { "SetScreenSaverDelay": "root.ScreenSaver.SetScreenSaverDelay" }
        }
      }
    },

    "TimeNTP": {
      "type": "object",
      "title": "Zeit & NTP",
      "propertyOrder": 70,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "ForceTimeServer": { "type": "boolean", "default": false, "title": "2.2.1 NTP-Server/Zeitzone setzen" },
        "TimeServer": {
          "type": "string",
          "default": "time.apple.com",
          "title": "NTP-Server",
          "options": {
            "hidden": false,
            "show_if": { "ForceTimeServer": true }
          },
          "watch": { "ForceTimeServer": "root.TimeNTP.ForceTimeServer" }
        },
        "DefaultTimeZone": {
          "type": "string",
          "default": "",
          "title": "Zeitzone (z. B. Europe/Berlin)",
          "options": {
            "hidden": false,
            "show_if": { "ForceTimeServer": true }
          },
          "watch": { "ForceTimeServer": "root.TimeNTP.ForceTimeServer" }
        }
      }
    },

    "System": {
      "type": "object",
      "title": "System",
      "propertyOrder": 75,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "CheckSystemUptime": {
          "type": "string",
          "default": "check",
          "title": "System-Laufzeit prüfen",
          "description": "Überwacht die Laufzeit seit dem letzten Neustart. Überschreitet das Gerät den Warnwert, meldet Notary eine Reboot-Empfehlung; überschreitet es den Maximalwert, wird das als kritischer Befund gewertet.",
          "enum": ["hard-check", "check", "off"],
          "options": {
            "enum_titles": ["Prüfen (Kritisch)", "Prüfen (Informativ)", "Ignorieren"]
          }
        },
        "SystemUptimeWarnDays": {
          "type": "integer",
          "default": 5,
          "title": "System uptime - Warn",
          "description": "Ab diesem Wert in Tagen empfiehlt Notary einen Neustart. Der Hinweis erscheint in der GUI und kann vom Hintergrunddienst mit Cooldown an den Benutzer gemeldet werden.",
          "enum": [3, 5, 7, 10, 14, 20, 30, 60],
          "options": {
            "enum_titles": ["3 Tage", "5 Tage", "7 Tage", "10 Tage", "14 Tage", "20 Tage", "30 Tage", "60 Tage"]
          }
        },
        "SystemUptimeMaxDays": {
          "type": "integer",
          "default": 0,
          "title": "System uptime - Max",
          "description": "Ab diesem Wert in Tagen wertet Notary die System-Laufzeit als kritischen Befund. `Deaktiviert` bedeutet, dass nur die Warnschwelle berücksichtigt wird.",
          "enum": [0, 5, 7, 10, 14, 20, 30, 60, 90],
          "options": {
            "enum_titles": ["Deaktiviert", "5 Tage", "7 Tage", "10 Tage", "14 Tage", "20 Tage", "30 Tage", "60 Tage", "90 Tage"]
          }
        }
      }
    },

    "SSH": {
      "type": "object",
      "title": "SSH & Remote Login",
      "propertyOrder": 78,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "DisableSSHPasswordAuthentication": {
          "type": "string",
          "default": "check",
          "title": "SSH Passwort- und Tastatur-Authentifizierung deaktivieren",
          "description": "Prüft oder erzwingt, dass sich Benutzer per SSH nicht mehr mit Passwort oder Tastatur-Interaktion anmelden können. Gedacht für Umgebungen, die nur noch Schlüssel-basierte SSH-Anmeldung erlauben.",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "ConfigureSSHClientAliveInterval": {
          "type": "string",
          "default": "check",
          "title": "SSH ClientAliveInterval konfigurieren",
          "description": "Prüft oder setzt den `ClientAliveInterval` des SSH-Servers. Damit trennt der Server inaktive SSH-Sitzungen nach einer definierten Zeitspanne kontrolliert.",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "SSHClientAliveInterval": {
          "type": "integer",
          "default": 900,
          "title": "ClientAliveInterval (Sekunden)",
          "description": "Legt fest, nach wie vielen Sekunden Inaktivität der SSH-Server ein Lebenszeichen vom Client erwartet.",
          "enum": [300, 600, 900, 1800, 3600],
          "options": {
            "enum_titles": ["5 Minuten", "10 Minuten", "15 Minuten", "30 Minuten", "60 Minuten"]
          }
        },
        "ConfigureSSHClientAliveCountMax": {
          "type": "string",
          "default": "check",
          "title": "SSH ClientAliveCountMax konfigurieren",
          "description": "Prüft oder setzt, wie viele unbeantwortete `ClientAlive`-Abfragen der SSH-Server zulässt, bevor er eine Sitzung beendet.",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "SSHClientAliveCountMax": {
          "type": "integer",
          "default": 0,
          "title": "ClientAliveCountMax",
          "description": "Legt fest, wie viele unbeantwortete `ClientAlive`-Pakete toleriert werden. `0` trennt die Sitzung sofort nach dem ersten ausbleibenden Lebenszeichen.",
          "enum": [0, 1, 2, 3],
          "options": {
            "enum_titles": ["0", "1", "2", "3"]
          }
        }
      }
    },

