    "PowerManagement": {
      "type": "object",
      "title": "Energie & Schlaf",
      "propertyOrder": 90,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "DisableWOMP": {
          "type": "string",
          "default": "check",
          "title": "2.8 Wake on Network (WOMP) deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "DisablePowerNap": {
          "type": "string",
          "default": "check",
          "title": "2.9 Power Nap deaktivieren (nur Intel CPU)",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "ForceHibernateOnSleep": {
          "type": "string",
          "default": "check",
          "title": "5.10 Hibernate auf Sleep erzwingen",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "DestroyFileVaultKeyOnStandby": {
          "type": "string",
          "default": "check",
          "title": "5.10.1 DestroyFileVaultKeyOnStandby aktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        }
      }
    },

    "LoginWindow": {
      "type": "object",
      "title": "Login-Fenster & Sicherheit",
      "propertyOrder": 100,
      "options": { "collapsed": false },
      "additionalProperties": false,
      "properties": {
        "DisableAutomaticLogin": {
          "type": "string",
          "default": "check",
          "title": "5.8 Automatischen Login deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
