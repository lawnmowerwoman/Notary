        },
        "DisableDVDSharing": {
          "type": "string",
          "default": "check",
          "title": "2.4.6 CD/DVD-Freigabe deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
          "options": {
            "enum_titles": ["Erzwingen (Hard fail)", "Erzwingen (Best Effort)", "Ignorieren", "Prüfen (Informativ)", "Prüfen (Kritisch)"]
          }
        },
        "DisableFileSharing": {
          "type": "string",
          "default": "check",
          "title": "2.4.8 Dateifreigabe deaktivieren",
          "enum": ["hard-enforce", "enforce", "off", "check", "hard-check"],
